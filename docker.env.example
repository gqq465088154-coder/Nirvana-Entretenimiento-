# Copy this file to docker.env and fill in real values before deploying.
# docker.env is NOT committed to version control.

# PostgreSQL
POSTGRES_DB=nirvana
POSTGRES_USER=nirvana
POSTGRES_PASSWORD=change-me-strong-password

# Backend
NODE_ENV=production
PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=2h
AUTH_USER=nirvana-admin
AUTH_PASSWORD=replace-with-a-strong-password

# Database connection (must match postgres service above)
POSTGRES_URL=postgresql://nirvana:change-me-strong-password@postgres:5432/nirvana
REDIS_URL=redis://redis:6379
